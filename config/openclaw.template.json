{
  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "token"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-20250514"
      },
      "contextTokens": 200000,
      "memorySearch": {
        "enabled": true,
        "sources": ["memory"],
        "provider": "openai"
      },
      "thinkingDefault": "low"
    }
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "",
      "groupPolicy": "allowlist",
      "dmPolicy": "allowlist",
      "allowFrom": [],
      "historyLimit": 16,
      "streaming": "partial"
    }
  },
  "commands": {
    "ownerAllowFrom": []
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback"
  },
  "plugins": {
    "entries": {
      "discord": {
        "enabled": true,
        "config": {}
      }
    }
  }
}
